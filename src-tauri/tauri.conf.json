{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FluorCast",
  "version": "0.1.0",
  "identifier": "org.fluorcast.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "FluorCast",
        "width": 1100,
        "height": 720,
        "minWidth": 760,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Science",
    "shortDescription": "Desktop controller for FluorCast predictions",
    "longDescription": "Prepare and manage molecular fluorescence prediction jobs running on NIBI."
  }
}
